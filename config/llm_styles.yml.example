styles:
  default:
    title: "по умолчанию"
    instruction: ""

  neutral:
    title: "нейтральный"
    instruction: "Стиль нейтральный, живой и естественный. Как хороший игровой рассказчик."

  funny:
    title: "смешной"
    instruction: "Стиль лёгкий, смешной, ироничный, с абсурдным юмором, но без полного бреда."

  dark:
    title: "мрачный"
    instruction: "Стиль мрачный, тревожный, с атмосферой опасности или упадка."

  grim:
    title: "жесткий"
    instruction: "Стиль суровый, приземлённый, грубоватый, будто в грязном и опасном мире."

  epic:
    title: "эпичный"
    instruction: "Стиль немного героический и пафосный, но короткий и уместный."

  bookish:
    title: "книжный"
    instruction: "Стиль чуть более литературный, будто короткая фраза из приключенческого рассказа."

  mystic:
    title: "мистический"
    instruction: "Стиль загадочный, немного мистический, с ощущением странной находки."

  sarcastic:
    title: "саркастичный"
    instruction: "Стиль саркастичный, с лёгкой насмешкой над происходящим, но без злобы."

  adventure:
    title: "приключенческий"
    instruction: "Стиль приключенческий, бодрый, как в сцене поиска трофеев."

  absurd:
    title: "абсурдный"
    instruction: "Стиль намеренно абсурдный и странный, но фраза всё равно должна звучать грамотно и естественно."