providers:
  default:
    provider: openai
    models:
      - name: name1
        api_key: YOUR_KEY_1
        base_url: https://api.openai.com/v1
        model: gpt-4.1-mini
      - name: name2
        api_key: YOUR_KEY_2
        base_url: https://api.openai.com/v1
        model: gpt-4.1-mini
      - name: name3
        api_key: YOUR_KEY_3
        base_url: https://api.openai.com/v1
        model: gpt-4.1-mini

  loot:
    provider: openai
    models:
      - name: name1
        api_key: YOUR_KEY_4
        base_url: https://api.openai.com/v1
        model: gpt-4.1-mini
      - name: name2
        api_key: YOUR_KEY_5
        base_url: https://api.openai.com/v1
        model: gpt-4.1-mini

  creative:
    provider: openai
    models:
      - name: name1
        api_key: YOUR_KEY_6
        base_url: https://api.openai.com/v1
        model: gpt-4.1

  strict_json:
    provider: openai
    models:
      - name: name1
        api_key: YOUR_KEY_7
        base_url: https://api.openai.com/v1
        model: gpt-4.1-mini

feature_settings:
  chat:
    provider: default
    temperature: 0.7
    max_output_tokens: 400
    style: random

  dossier:
    provider: creative
    temperature: 0.9
    max_output_tokens: 500
    style: default

  weekly_movies:
    provider: default
    temperature: 0.5
    max_output_tokens: 300
    style: epic

  user_memory:
    provider: strict_json
    temperature: 0.2
    max_output_tokens: 800

  dynamic_prompt:
    provider: loot
    temperature: 0.8
    max_output_tokens: 400
    style: default
