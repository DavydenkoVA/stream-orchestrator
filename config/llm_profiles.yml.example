providers:
  default:
    provider: openai
    api_key_env: LLM_API_KEY
    base_url: https://api.openai.com/v1
    model: gpt-4.1-mini

  creative:
    provider: openai
    api_key_env: LLM_API_KEY
    base_url: https://api.openai.com/v1
    model: gpt-4.1

  strict_json:
    provider: openai
    api_key_env: LLM_API_KEY
    base_url: https://api.openai.com/v1
    model: gpt-4.1-mini

feature_settings:
  chat:
    provider: default
    temperature: 0.7
    max_output_tokens: 400

  dossier:
    provider: creative
    temperature: 0.9
    max_output_tokens: 500

  weekly_movies:
    provider: default
    temperature: 0.5
    max_output_tokens: 300

  user_memory:
    provider: strict_json
    temperature: 0.2
    max_output_tokens: 800

  dynamic_prompt:
    provider: creative
    temperature: 0.8
    max_output_tokens: 400